<script>
  (function() {
    // ---------- константы и утилиты ----------
    const CIRC = 2 * Math.PI * 44; // ≈ 276.46

    function animateRing(slideEl) {
      const pct = parseInt(slideEl.getAttribute('data-pct'), 10) / 100;
      const ring = slideEl.querySelector('.ring-track');
      if (!ring) return;
      const target = (CIRC * pct).toFixed(2);
      let start = null;
      function step(timestamp) {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / 900, 1); // 900ms
        const ease = 1 - Math.pow(1 - progress, 3); // cubic-out
        ring.setAttribute('stroke-dasharray', (target * ease).toFixed(2) + ' ' + CIRC.toFixed(2));
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function resetRing(slideEl) {
      const ring = slideEl.querySelector('.ring-track');
      if (ring) ring.setAttribute('stroke-dasharray', '0 ' + CIRC);
    }

    // ---------- инициализация Swiper с плавным свайпом ----------
    const swiper = new Swiper('.product-slider', {
      speed: 650,                          // длительность перехода (мс)
      spaceBetween: 30,
      effect: 'slide',                      // именно slide даёт перетаскивание
      loop: false,
      navigation: { nextEl: '.next', prevEl: '.prev' },
      grabCursor: true,                     // курсор "рука" при перетаскивании
      on: {
        init: function () {
          const slides = document.querySelectorAll('.product-slider__item');
          const first = slides[this.activeIndex];
          const targetId = first.getAttribute('data-target');
          document.querySelectorAll('.product-img__item').forEach(el => el.classList.remove('active'));
          document.getElementById(targetId)?.classList.add('active');
          setTimeout(() => animateRing(first), 600); // задержка как в методичке
          // обновить кнопки
          document.querySelector('.prev').classList.toggle('disabled', this.isBeginning);
          document.querySelector('.next').classList.toggle('disabled', this.isEnd);
        },
        slideChangeTransitionStart: function () {
          // момент начала перехода — сбрасываем кольцо предыдущего слайда
          const slides = document.querySelectorAll('.product-slider__item');
          const prev = slides[this.previousIndex];
          if (prev) resetRing(prev);
        },
        slideChangeTransitionEnd: function () {
          // окончание перехода — обновляем картинку, запускаем анимацию кольца
          const slides = document.querySelectorAll('.product-slider__item');
          const active = slides[this.activeIndex];
          const targetId = active.getAttribute('data-target');
          document.querySelectorAll('.product-img__item').forEach(el => el.classList.remove('active'));
          document.getElementById(targetId)?.classList.add('active');

          setTimeout(() => animateRing(active), 150); // небольшая задержка после смены

          // disabled-состояния
          document.querySelector('.prev').classList.toggle('disabled', this.isBeginning);
          document.querySelector('.next').classList.toggle('disabled', this.isEnd);
        }
      }
    });

    // кнопка "в избранное" (демо)
    document.querySelectorAll('.js-fav').forEach(btn => {
      btn.addEventListener('click', function () {
        this.classList.toggle('is-active');
      });
    });

  })();
</script>
